{
  "name": "controlpanel/api",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "laravel/reverb": "^1.0",
    "laravel/sanctum": "^4.0",
    "firebase/php-jwt": "^6.11",
    "web-auth/webauthn-lib": "^4.9",
    "pragmarx/google2fa-laravel": "^2.3",
    "guzzlehttp/guzzle": "^7.9"
  },
  "require-dev": {
